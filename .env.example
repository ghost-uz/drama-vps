# ==============================================================================
# Drama.uz — .env namunasi
# Bu faylni nusxa olib, .env deb nomlang va qiymatlarni to'ldiring:
#   cp .env.example .env
# ==============================================================================

# Django asosiy sozlamalar
# Yangi SECRET_KEY: python -c "import secrets; print('django-insecure-' + secrets.token_urlsafe(50))"
# MUHIM: $ belgisini ishlatmang — Docker Compose .env interpolatsiyasini buzadi
# (get_random_secret_key() $ qo'shadi, shuning uchun token_urlsafe ishlating).
SECRET_KEY=your-secret-key-here
DEBUG=False

# Ma'lumotlar bazasi (PostgreSQL)
DB_NAME=drama_db
DB_USER=drama_user
DB_PASSWORD=your-db-password-here
DB_HOST=127.0.0.1
DB_PORT=5432

# Redis (kesh + sessiya + Celery broker)
# DB indekslari: /1 = kesh, /0 = Celery broker, /2 = Celery natija
REDIS_URL=redis://127.0.0.1:6379/1

# Telegram Bot (Admin xabarnomalar uchun)
# Bot yaratish: @BotFather orqali
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Chat ID olish: @userinfobot botiga /start yozing
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id-here

# Bunny Stream CDN (video uzatish uchun)
# Bunny dashboard → Stream > Library > Library ID
BUNNY_STREAM_LIBRARY_ID=your-library-id-here
# Bunny dashboard → Stream > Library > CDN Hostname (masalan: vz-abc12345.b-cdn.net)
BUNNY_STREAM_CDN_HOSTNAME=vz-xxxxxxxx.b-cdn.net
# Bunny dashboard → Account > API Key
BUNNY_STREAM_API_KEY=your-api-key-here
# Stream Library → Security → Token Authentication Key [P4-T1]
# Yoqish tartibi MUHIM (avval kod, keyin panel) — docs/ops/bunny.md ga qarang.
# Bo'sh qoldirilsa URL'lar imzosiz chiqadi (dev rejim).
BUNNY_STREAM_TOKEN_KEY=
# Imzolangan URL muddati, sekund (default 4 soat = 14400)
BUNNY_TOKEN_EXPIRY_SECONDS=14400
# Token'ni mijoz IP'siga bog'lash — EHTIYOT: docs/ops/bunny.md ogohlantirishisiz yoqmang
BUNNY_TOKEN_BIND_IP=False
# Bunny webhook siri (encoding-tugadi signali) [P3-T2]
# Bunny panel webhook URL: https://drama.uz/webhooks/bunny/?secret=SHU_QIYMAT
BUNNY_WEBHOOK_SECRET=

# ==============================================================================
# Docker / Deployment (P0-T6)
# ==============================================================================

# Qaysi settings moduli yuklanadi:
#   dev:  config.settings.dev    (DEBUG=True, lokal FS storage, kalitsiz)
#   prod: config.settings.prod   (DEBUG=False, GCS, SMTP)
# Dev stack (docker-compose.dev.yml) buni avtomatik config.settings.dev ga o'tkazadi.
DJANGO_SETTINGS_MODULE=config.settings.prod

# nginx tashqi porti (host -> nginx:80)
WEB_PORT=80

# Logging darajasi (prod.py)
LOG_LEVEL=INFO

# Celery — Docker'da redis://redis:6379/... ga avtomatik override qilinadi.
# DB indekslari: /0 = broker, /2 = natija (kesh /1 dan alohida).
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# --- Email (SMTP) — faqat prod ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=admin@drama.uz

# --- Google Cloud Storage (faqat prod) ---
# Prod Docker'da GCS kalit faylini konteynerga mount qilib, bu yerda yo'lini bering:
#   web/celery volumes: - /host/yo'l/gcs-key.json:/app/secrets/gcs-key.json:ro
#   GS_CREDENTIALS_FILE=/app/secrets/gcs-key.json
# Dev'da bo'sh qoldiring (dev.py GCS ishlatmaydi).
GS_CREDENTIALS_FILE=
