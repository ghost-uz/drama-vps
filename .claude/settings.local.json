{
  "permissions": {
    "allow": [
      "PowerShell(Get-Command python)",
      "PowerShell(Get-Command python3 -ErrorAction SilentlyContinue | Select-Object Source; Get-Command py -ErrorAction SilentlyContinue | Select-Object Source; $env:PATH -split ';' | Where-Object { $_ -match 'python|venv|env' })",
      "Bash(python3 -c \"import django; print\\(django.__version__\\)\")",
      "Bash(python manage.py makemigrations users --name=\"add_crypto_topup_request\")",
      "Bash(python -c \"import sys; print\\(sys.executable\\)\")",
      "Bash(where python *)",
      "Bash(python -m pip show django)",
      "PowerShell(Get-ChildItem \"c:\\\\projects\\\\drama-vps\" | Where-Object { $_.Name -match \"requirements|venv|env|\\\\.toml|\\\\.cfg\" } | Select-Object Name)",
      "PowerShell(Get-ChildItem \"c:\\\\projects\\\\drama-vps\" -Recurse -Depth 2 | Where-Object { $_.Name -eq \"python.exe\" } | Select-Object FullName)",
      "PowerShell(py -3.12 -m django --version 2>&1)",
      "PowerShell(py --list 2>&1)"
    ]
  }
}
